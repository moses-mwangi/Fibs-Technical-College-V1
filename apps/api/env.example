# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (Optional - Demo mode works without database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fibs_college
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# College Configuration
COLLEGE_NAME=FIBS Driving and Technical College
COLLEGE_ADDRESS=Kenya
COLLEGE_PHONE=+254 700 000 000
COLLEGE_EMAIL=info@fibscollege.com
