{
  "files": [],
  "references": [
    { "path": "./packages" },
    { "path": "./apps" }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@repo/*": ["./packages/*/src"],
      "@fibs/*": ["./apps/*/src"]
    },
    "files": [],
  "references": [
    { "path": "apps/web" }
  ]
  }
}
